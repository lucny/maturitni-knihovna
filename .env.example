COMPOSE_PROJECT_NAME=maturitni-knihovna

CADDY_IMAGE=caddy:2-alpine
FRONTEND_IMAGE=node:22-alpine
POCKETBASE_IMAGE=ghcr.io/muchobien/pocketbase:latest

APP_DOMAIN=localhost
POCKETBASE_DOMAIN=pb.localhost
REVERSE_PROXY_HOST=127.0.0.1
REVERSE_PROXY_HTTP_PORT=80

# Production HTTPS reverse proxy.
# Set these only in the real deployment environment.
PUBLIC_APP_DOMAIN=library.example.com
PUBLIC_POCKETBASE_DOMAIN=pb.library.example.com
TLS_CONTACT_EMAIL=admin@example.com
REVERSE_PROXY_HTTPS_HOST=0.0.0.0
REVERSE_PROXY_HTTPS_PORT=443

# Public browser-facing URLs.
PUBLIC_APP_URL=http://localhost
PUBLIC_POCKETBASE_URL=http://pb.localhost

# Internal Docker URL used by SvelteKit server-side code.
POCKETBASE_URL=http://pocketbase:8090

# Direct PocketBase port is kept localhost-only for local development.
POCKETBASE_HOST=127.0.0.1
POCKETBASE_PORT=8090

# Configure these values in Microsoft Entra ID and PocketBase Admin UI.
# Do not commit real secrets.
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_CLIENT_SECRET=replace-with-client-secret
MICROSOFT_REDIRECT_URI=http://localhost/auth/callback/microsoft

# Production redirect URI example:
# MICROSOFT_REDIRECT_URI=https://library.example.com/auth/callback/microsoft
