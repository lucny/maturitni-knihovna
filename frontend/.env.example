# Docker Compose reverse proxy defaults.
PUBLIC_POCKETBASE_URL=http://pb.localhost
POCKETBASE_URL=http://pocketbase:8090
PUBLIC_APP_URL=http://localhost

# Standalone npm run dev outside Docker can override these values:
# PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
# POCKETBASE_URL=http://127.0.0.1:8090
# PUBLIC_APP_URL=http://127.0.0.1:5173

# Production values are provided by docker-compose.prod.yml:
# PUBLIC_POCKETBASE_URL=https://pb.library.example.com
# POCKETBASE_URL=http://pocketbase:8090
# PUBLIC_APP_URL=https://library.example.com
